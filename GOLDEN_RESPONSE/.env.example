# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🚀 AURABLOG - PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# 🗄 DATABASE DESIGN (Default: Local SQLite)
# Swap provider to "postgresql" in prisma/schema.prisma and use Postgres URL to scale
DATABASE_URL="file:./dev.db"

# 🔐 AUTHENTICATION SYSTEM (NextAuth.js JWT)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secure-nextauth-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# 🤖 ARTIFICIAL INTELLIGENCE (OpenAI API - Fallbacks to Local NLP TF-IDF vectorizer if empty)
OPENAI_API_KEY=""

# ☁ CLOUD MEDIA STORAGE (Cloudinary - Fallbacks to Next.js local public directory if empty)
CLOUDINARY_NAME=""
CLOUDINARY_KEY=""
CLOUDINARY_SECRET=""

# ⚡ REDIS CACHING & RATE LIMITS (Upstash Redis - Fallbacks to memory cache maps if empty)
REDIS_URL=""

# 📩 SMTP TRANSACTIONAL EMAILS (Resend/Mailer - Fallbacks to terminal console logger if empty)
EMAIL_SERVER=""
EMAIL_FROM="noreply@aura.blog"
